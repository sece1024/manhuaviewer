{
  "name": "manhuaviewer",
  "version": "2.0.0",
  "description": "MangaViewer — 漫画阅读管理系统",
  "main": "electron/main.js",
  "scripts": {
    "start:backend": "pnpm --filter manhuaviewer-backend start",
    "start:frontend": "pnpm --filter manhuaviewer-frontend start",
    "start": "pnpm run start:backend & pnpm run start:frontend",
    "dev": "pnpm run start:backend & pnpm run start:frontend",
    "build": "pnpm --filter manhuaviewer-frontend build",
    "electron": "pnpm run build && electron .",
    "build:electron": "pnpm run build && electron-builder --mac",
    "pack": "pnpm run build && electron-builder --mac --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sece1024.manhuaviewer",
    "productName": "MangaViewer",
    "directories": {
      "output": "out"
    },
    "files": [
      "electron/**/*",
      "backend/src/**/*",
      "backend/package.json",
      "backend/node_modules/**/*",
      "frontend/build/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment"
    },
    "npmRebuild": true
  }
}
